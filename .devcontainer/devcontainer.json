{
  "name": "Score_Leads",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20",
  "features": {},
  "customizations": {
    "vscode": {
      "extensions": [
        "usernamehw.errorlens",
        "eamodio.gitlens",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.tabSize": 2,
        "files.eol": "\n"
      }
    }
  },
  "forwardPorts": [5173],
  "postCreateCommand": "npm install || echo 'No package.json yet — skipping npm install'",
  "remoteUser": "node"
}
